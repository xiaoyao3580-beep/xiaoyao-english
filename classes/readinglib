<!-- ==================== VIEW: SYNTAX ==================== -->
<div id="view-syntax" class="app-view wrap pb-40">
  <div class="desktop-card">
    <div class="flex justify-between items-center mb-4">
      <div>
        <h1 class="font-zcool text-2xl font-bold">长难句挑战 <span id="set-indicator" class="text-[var(--main)] ml-1">Level 1</span></h1>
        <div class="text-[11px] font-bold text-red-500 bg-red-50 inline-block px-2 py-0.5 rounded mt-1">🎯 目标：85%合格</div>
      </div>
      <div class="bg-white border-2 border-[var(--ink)] rounded-full px-4 py-1 font-bold text-sm flex items-center gap-2 h-fit">
        <i class="fas fa-clock text-gray-400"></i> <span id="s-timer" class="text-gray-600">00:00</span>
      </div>
    </div>

    <div class="guide-card !p-3 mb-6 flex items-center justify-between" style="background:#FFF9EC;">
      <div>
        <div class="font-bold text-[var(--sign)]"><i class="fas fa-map-signs"></i> 路标选择模式</div>
        <div class="text-[11px] text-gray-600">开启后点击句子中的连接词/介词</div>
      </div>
