<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>积木英语 · 综合闯关</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=ZCOOL+KuaiLe&family=Noto+Sans+SC:wght@400;500;700;900&family=Baloo+2:wght@600;700;800&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  
  <!-- 新增：引入 Supabase 官方 JS 库 -->
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  
  <style>
    :root{
      --paper:#FBF6EC; --paper2:#FFFDF8; --ink:#2E2A26; --ink-soft:#6B6258;
      --main:#E8552B;  --main-bg:#FBE2D8;
      --clause:#2D7DD2; --clause-bg:#DCEAFA;
      --verb:#1F9D57; --verb-bg:#D9F0E2;
      --prep:#D69412; --prep-bg:#F7E9C8;
      --sign:#7C4DD6; --sign-bg:#EADFFB;
      --shadow:0 6px 0 rgba(0,0,0,.06), 0 14px 30px rgba(46,42,38,.10);
    }

    *{box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{
      margin:0;
      background: radial-gradient(circle at 12% 8%, #fff5dd 0, transparent 40%), radial-gradient(circle at 88% 4%, #ffe6dd 0, transparent 38%), var(--paper);
      color:var(--ink);
      font-family:"Noto Sans SC","Nunito",sans-serif;
      line-height:1.75; -webkit-font-smoothing:antialiased;
      overscroll-behavior-y: none;
      padding-bottom: 80px;
    }

    /* Layout & Utilities */
    .wrap{max-width:880px;margin:0 auto;padding:20px 20px 90px}
    .desktop-card{max-width:640px;margin:0 auto}
    .app-view { display: none; }
    .app-view.active { display: block; animation: fadeIn 0.3s ease; }
    @keyframes fadeIn { from{opacity:0;transform:translateY(10px)} to{opacity:1;transform:none} }

    /* Navigation */
    .nav-bar {
      position: sticky; top: 0; z-index: 40; 
      background: rgba(251, 246, 236, 0.9); backdrop-filter: blur(10px);
      border-bottom: 2px solid var(--ink);
      padding: 10px 20px; display: flex; justify-content: center; gap: 8px;
    }
    .nav-btn {
      font-family: "Baloo 2", "Noto Sans SC"; font-weight: 700; font-size: 15px;
      padding: 8px 16px; border: 2px solid transparent; border-radius: 999px;
      color: var(--ink-soft); transition: all 0.2s; cursor: pointer;
    }
    .nav-btn.active {
      background: var(--ink); color: #fff; border-color: var(--ink);
      box-shadow: 0 4px 0 rgba(0,0,0,0.1); transform: translateY(-2px);
    }

    /* Cards */
    .guide-card{ background:var(--paper2);border:2px solid var(--ink);border-radius:20px; padding:22px 22px;box-shadow:var(--shadow); margin-bottom: 18px; position:relative; overflow:hidden;}
    .guide-card p{margin:.6em 0}
    .guide-card b, .guide-card strong{font-weight:800}
    
    .cover{
      position:relative; background:linear-gradient(135deg,#fff 0,#FFF7E9 100%);
      border:3px solid var(--ink); border-radius:28px; padding:38px 32px 34px;
      box-shadow:var(--shadow); overflow:hidden; margin-bottom: 24px;
    }
    .cover .blob{position:absolute;border-radius:50%;filter:blur(2px);opacity:.5}
    .cover .b1{width:120px;height:120px;background:var(--main-bg);right:-30px;top:-30px}
    .cover .b2{width:90px;height:90px;background:var(--clause-bg);left:-26px;bottom:-26px}
    .kicker{font-family:"Nunito";font-weight:800;letter-spacing:2px;text-transform:uppercase;color:var(--main);font-size:13px}
    .cover h1{ font-family:"ZCOOL KuaiLe","Baloo 2",cursive; font-size:clamp(30px,6vw,46px); line-height:1.2;margin:.25em 0 .15em;color:var(--ink); position:relative;z-index:1; }

    .blocks-demo{display:flex;flex-wrap:wrap;gap:10px;align-items:stretch;margin:12px 0}
    .blk{ border-radius:12px;padding:10px 14px;font-family:"Baloo 2";font-weight:700;font-size:15px; border:2px solid;display:flex;flex-direction:column;gap:2px;min-width:0 }
    .blk small{font-family:"Noto Sans SC";font-weight:500;font-size:12px;opacity:.85}
    .blk.main{background:var(--main-bg);border-color:var(--main);color:#9c3414}
    .blk.clause{background:var(--clause-bg);border-color:var(--clause);color:#1a4f86}
    .blk.verb{background:var(--verb-bg);border-color:var(--verb);color:#136b3b}
    .blk.prep{background:var(--prep-bg);border-color:var(--prep);color:#8a5e08}
    .blk.sign{background:var(--sign-bg);border-color:var(--sign);color:#5a32a8}

    .action-btn-large {
      display: block; width: 100%; background: var(--ink); color: #fff;
      font-family: "ZCOOL KuaiLe", cursive; font-size: 22px; padding: 14px;
      border-radius: 18px; border: 2px solid var(--ink); text-align: center;
      box-shadow: 0 6px 0 var(--ink-soft); transition: all 0.1s; cursor: pointer;
    }
    .action-btn-large:active { transform: translateY(4px); box-shadow: 0 2px 0 var(--ink-soft); }

    /* Vocab Drill */
    .vocab-title { font-family: "Baloo 2"; font-weight: 800; font-size: 42px; line-height: 1; text-align: center; margin-bottom: 4px; }
    .vocab-phon { text-align: center; color: var(--ink-soft); font-family: "Nunito"; font-size: 15px; margin-bottom: 12px; }
    .vocab-ans { border-top: 2px dashed var(--line); padding-top: 20px; margin-top: 10px; }
    
    .action-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px; margin-top:20px}
    .v-btn{ border:2px solid var(--ink); border-radius:16px; padding:12px 8px; font-weight:800; text-align:center; box-shadow:0 4px 0 rgba(0,0,0,.15); transition:.1s; background:#fff; cursor:pointer;}
    .v-btn:active{ transform:translateY(2px); box-shadow:0 2px 0 rgba(0,0,0,.15); }
    .v-btn i { font-size: 24px; margin-bottom: 6px; display: block; }
    .v-no { background: #FFE8E8; color: var(--red-deep); border-color: var(--red-deep); }
    .v-meh { background: #FFF4E0; color: #A66B05; border-color: #A66B05; }
    .v-know { background: #E8F5E9; color: #1B5E20; border-color: #1B5E20; }

    .prog-track { height: 12px; background: #EEE; border: 2px solid var(--ink); border-radius: 999px; overflow: hidden; margin-bottom: 15px; }
    .prog-fill { height: 100%; background: var(--main); transition: width 0.3s; }

    /* Syntax Drill */
    .sentence-container { font-family: "Nunito"; font-size: 18px; font-weight: 700; line-height: 2.2; color: var(--ink); }
    .chunk-container{display:inline-flex;flex-direction:column;align-items:center;margin:4px 3px;vertical-align:top}
    .chunk-text{border-bottom:2px solid #ddd;padding-bottom:2px;}
    
    .dropzone{min-height:38px;width:100%;min-width:60px;border:2px dashed #a8a29e;background:#f5f5f4;border-radius:8px;margin-top:6px;display:flex;align-items:center;justify-content:center;transition:all .2s;padding:2px}
    .dropzone.drag-over{background:var(--main-bg);border-color:var(--main);transform:scale(1.05)}
    .dropzone.filled{border-style:solid; cursor:pointer;}

    .draggable-tag{cursor:grab;touch-action:none;user-select:none;display:flex;flex-direction:column;align-items:center;padding:6px 12px;border:2px solid;border-radius:12px;font-weight:800;font-size:14px;box-shadow:0 3px 0 rgba(0,0,0,.12);background:#fff}
    .draggable-tag:active{cursor:grabbing;transform:scale(.95)}
    .draggable-tag span:last-child{font-size:10px;font-weight:500;opacity:.8}

    #drag-ghost {position:fixed;pointer-events:none;z-index:9999;opacity:.9;transform:translate(-50%,-50%) scale(1.1);box-shadow:0 10px 25px rgba(0,0,0,.2)}

    .tag-bank-wrapper{position:fixed;bottom:0;left:0;right:0;background:rgba(251,246,236,.95);backdrop-filter:blur(10px);border-top:2px solid var(--ink);padding:12px 10px calc(12px + env(safe-area-inset-bottom));z-index:40;box-shadow:0 -10px 30px rgba(0,0,0,.06)}

    .mode-signpost-active .chunk-container { opacity: 0.5; pointer-events: none; }
    .mode-signpost-active .tag-bank-wrapper { opacity: 0.3; pointer-events: none; }
    .clickable-word { display: inline-block; padding: 2px 4px; margin: 0 1px; border-radius: 6px; border: 2px solid transparent; transition: all 0.2s; cursor: pointer; }
    .mode-signpost-active .clickable-word { border-color: #d6d3d1; background: #fff; }
    .mode-signpost-active .clickable-word.selected { background: var(--sign); color: white; border-color: var(--sign); box-shadow: 0 3px 0 rgba(0,0,0,0.2); transform: translateY(-2px); }

    .p-main{background:var(--main-bg);box-shadow:0 0 0 2px var(--main) inset;border-radius:5px;padding:0 4px}
    .p-clause{background:var(--clause-bg);box-shadow:0 0 0 2px var(--clause) inset;border-radius:5px;padding:0 4px}
    .p-verb{background:var(--verb-bg);box-shadow:0 0 0 2px var(--verb) inset;border-radius:5px;padding:0 4px}
    .p-prep{background:var(--prep-bg);box-shadow:0 0 0 2px var(--prep) inset;border-radius:5px;padding:0 4px}
    .p-sign{color:var(--sign);font-weight:800;text-decoration:underline;text-decoration-color:var(--sign);text-underline-offset:3px}

    /* Modal */
    .modal-overlay { fixed inset-0 bg-black/60 z-50 hidden items-center justify-center backdrop-blur-sm p-4 }
    .modal-card { background: var(--paper2); border: 3px solid var(--ink); border-radius: 24px; box-shadow: var(--shadow); width: 100%; max-width: 500px; max-height: 80vh; overflow-y: auto; padding: 24px; position: relative; }
    
    /* Report Styles */
    .report-table-row { display: grid; grid-template-columns: 3fr 2fr 3fr 2fr; gap: 8px; align-items: center; padding: 12px 0; border-bottom: 1px dashed var(--line); font-size: 13px; font-weight: bold;}
    .report-table-row:last-child { border-bottom: none; }
    @media(max-width: 500px) {
        .report-table-row { grid-template-columns: 1fr; gap: 4px; padding: 10px 0; }
        .report-table-row > div:first-child { font-size: 15px; margin-bottom: 4px;}
    }
  </style>
</head>
<body>

