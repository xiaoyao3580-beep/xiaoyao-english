  }
}

function formatTime(seconds) {
  const m = Math.floor(seconds / 60); const s = seconds % 60;
  return `${m.toString().padStart(2, '0')}:${s.toString().padStart(2, '0')}`;
}
function formatDate(isoString) {
  if(!isoString) return '尚未进行';
  const d = new Date(isoString);
  return `${d.getMonth()+1}月${d.getDate()}日 ${d.getHours().toString().padStart(2,'0')}:${d.getMinutes().toString().padStart(2,'0')}`;
}

function switchTab(tab) {
  const activeView = document.querySelector('.app-view.active');
  const leavingTab = activeView ? activeView.id.replace('view-', '') : null;

  ['guide', 'vocab', 'syntax', 'report'].forEach(t => {
    document.getElementById('view-' + t).classList.remove('active');
    document.getElementById('tab-' + t).classList.remove('active');
  });
  document.getElementById('view-' + tab).classList.add('active');
  document.getElementById('tab-' + tab).classList.add('active');
  window.scrollTo(0,0);
  
  clearInterval(timerIntervals.vocab); 
  clearInterval(timerIntervals.syntax);

  // 处理离开测试标签页：进度和计时自动清零
  if (leavingTab === 'vocab' && tab !== 'vocab') {
    if (!state.vocab.done) {
      state.vocab.words.forEach(w => { w.firstRes = null; w.peeked = false; });
      state.vocab.queue = state.vocab.words.map(w => w.id).sort(() => Math.random() - 0.5);
      state.vocab.mastered = 0;
      state.vocab.timeSpent = 0;
      state.vocab.startTime = null;
      saveData();
      renderVocab();
    }
  }

  if (leavingTab === 'syntax' && tab !== 'syntax') {
    state.syntax.startTime = null;
    state.syntax.answers = {};
    if (document.getElementById('syntax-container').children.length > 0) {
        renderSyntaxSet(); // 清空当前做了一半的选项
    }
    document.getElementById('s-timer').textContent = "00:00";
  }
  
  // 处理进入测试标签页：开始/重置计时
  if (tab === 'vocab' && !state.vocab.done) {
    state.vocab.timeSpent = 0; // 确保计时从0开始
    state.vocab.startTime = Date.now();
    document.getElementById('v-timer').textContent = "00:00";
    timerIntervals.vocab = setInterval(() => {
      const ms = Date.now() - state.vocab.startTime;
      document.getElementById('v-timer').textContent = formatTime(Math.floor(ms/1000));
    }, 1000);
  } else if (tab === 'syntax') {
    if (document.getElementById('syntax-container').children.length === 0) {
        navToSyntax(false);
    }
    state.syntax.startTime = Date.now(); // 确保计时从0开始
    document.getElementById('s-timer').textContent = "00:00";
    timerIntervals.syntax = setInterval(() => {
      const ms = Date.now() - state.syntax.startTime;
      document.getElementById('s-timer').textContent = formatTime(Math.floor(ms/1000));
    }, 1000);
  }
}

function renderVocab() {
  if(state.vocab.done || state.vocab.mastered >= state.vocab.words.length) {
    document.getElementById('vocab-play-area').classList.add('hidden');
    document.getElementById('vocab-done-area').classList.remove('hidden');
    state.vocab.done = true;
    if(state.vocab.startTime) {
       state.vocab.timeSpent += (Date.now() - state.vocab.startTime);
       state.vocab.startTime = null;
       state.vocab.lastDate = new Date().toISOString();
       saveData();
    }
  } else {
    document.getElementById('vocab-play-area').classList.remove('hidden');
    document.getElementById('vocab-done-area').classList.add('hidden');
    
    const wordIdx = state.vocab.queue[0];
    const w = state.vocab.words[wordIdx];
    
    document.getElementById('v-en').textContent = w.en;
    document.getElementById('v-phon').textContent = w.phon;
    document.getElementById('v-cn').textContent = w.cn;
    document.getElementById('v-ex').textContent = w.ex;
    
    document.getElementById('v-ans-area').classList.add('hidden');
    document.getElementById('v-reveal-btn').classList.remove('hidden');
    // Action buttons are always visible as requested
  }
  
  document.getElementById('v-mastered').textContent = state.vocab.mastered;
  document.getElementById('v-total').textContent = state.vocab.words.length;
  document.getElementById('v-progress').style.width = (state.vocab.mastered / state.vocab.words.length * 100) + '%';
}

function revealVocab() {
  const currentIdx = state.vocab.queue[0];
  state.vocab.words[currentIdx].peeked = true;
  document.getElementById('v-reveal-btn').classList.add('hidden');
  document.getElementById('v-ans-area').classList.remove('hidden');
}

function markVocab(result) {
  const currentIdx = state.vocab.queue.shift();
  const w = state.vocab.words[currentIdx];
  
  if(!w.firstRes) {
      w.firstRes = result;
      // if they mark 'know' without ever clicking reveal, peeked remains false.
  }
  
  if(result === 'know') {
    state.vocab.mastered++;
  } else if (result === 'meh') {
    const pos = Math.min(state.vocab.queue.length, 3);
    state.vocab.queue.splice(pos, 0, currentIdx);
  } else {
    const pos = Math.min(state.vocab.queue.length, 1);
    state.vocab.queue.splice(pos, 0, currentIdx);
  }
  
  saveData();
  renderVocab();
}

function resetVocab() {
  state.vocab.words.forEach(w => { w.firstRes = null; w.peeked = false; });
  state.vocab.queue = state.vocab.words.map(w => w.id).sort(() => Math.random() - 0.5);
  state.vocab.mastered = 0; state.vocab.done = false; state.vocab.timeSpent = 0; state.vocab.startTime = Date.now();
  saveData();
  renderVocab();
  switchTab('vocab');
}

function navToSyntax(doSwitch = true) {
  // Find highest unlocked level
  let targetIdx = 0;
  for(let i=0; i<7; i++) {
    if(state.syntax.levels[i].status === 'unlocked' || state.syntax.levels[i].status === 'passed') targetIdx = i;
    if(state.syntax.levels[i].status === 'locked') break;
  }
  
  if (state.syntax.levels[targetIdx].questions.length === 0) {
    startSyntaxLevel(targetIdx);
  } else {
    state.syntax.activeLevelIdx = targetIdx;
    renderSyntaxSet();
  }
  
  if(doSwitch) switchTab('syntax');
}

function startSyntaxLevel(idx) {
  state.syntax.activeLevelIdx = idx;
  const level = state.syntax.levels[idx];
  
  // Feature: Randomly draw 6 questions from the 80 question pool
  const shuffledPool = [...SYNTAX_POOL].sort(() => Math.random() - 0.5);
  level.questions = shuffledPool.slice(0, 6);
  
  state.syntax.startTime = Date.now();
  renderSyntaxSet();
}

function renderSyntaxSet() {
  const idx = state.syntax.activeLevelIdx;
  const level = state.syntax.levels[idx];
  
  document.getElementById('set-indicator').textContent = `Level ${idx + 1}`;
  
  const container = document.getElementById('syntax-container');
  container.innerHTML = '';
  state.syntax.answers = {};
  
  level.questions.forEach((q, index) => {
    state.syntax.answers[q.id] = { chunks: {}, signposts: [] };
    
    const card = document.createElement('div');
    card.className = 'sentence-card bg-white border border-gray-200 rounded-2xl p-5 shadow-sm mb-4';
    card.innerHTML = `<div class="text-xs font-bold text-gray-400 tracking-wider mb-4 border-b border-gray-100 pb-2"><span class="bg-indigo-50 text-[var(--clause)] px-2 py-1 rounded">Q${index + 1}</span></div>`;

    const sentenceBody = document.createElement('div');
    sentenceBody.className = 'sentence-container';

    let chunkCounter = 0; let wordCounter = 0;

    q.segments.forEach(seg => {
      if (seg.t === 'text') { sentenceBody.appendChild(document.createTextNode(seg.v)); } 
      else if (seg.t === 'word') {
        const span = document.createElement('span');
        span.className = 'clickable-word';
        span.dataset.qid = q.id; span.dataset.widx = wordCounter;
        span.textContent = seg.v;
        span.onclick = () => handleSignpostClick(q.id, span.dataset.widx, span);
        sentenceBody.appendChild(span);
        wordCounter++;
      }
      else if (seg.t === 'chunk') {
        const wrapper = document.createElement('span');
        wrapper.className = 'chunk-container';
        
        const textSpan = document.createElement('span');
        textSpan.className = 'chunk-text'; textSpan.textContent = seg.v;
        
        const dropzone = document.createElement('div');
        dropzone.className = 'dropzone'; dropzone.dataset.qid = q.id; dropzone.dataset.cidx = chunkCounter;
        dropzone.onclick = () => {
          if(!state.syntax.isSignpostMode && dropzone.classList.contains('filled')) {
            delete state.syntax.answers[q.id].chunks[dropzone.dataset.cidx];
            dropzone.className = 'dropzone'; dropzone.style = ''; dropzone.innerHTML = '';
          }
        };

        wrapper.appendChild(textSpan); wrapper.appendChild(dropzone);
        sentenceBody.appendChild(wrapper);
        chunkCounter++;
      }
    });
    card.appendChild(sentenceBody); container.appendChild(card);
  });
}

// Signpost Mode Toggle
document.getElementById('signpost-toggle').addEventListener('change', (e) => {
  state.syntax.isSignpostMode = e.target.checked;
  const view = document.getElementById('view-syntax');
  if(state.syntax.isSignpostMode) view.classList.add('mode-signpost-active');
  else view.classList.remove('mode-signpost-active');
});

function handleSignpostClick(qId, wIdxStr, el) {
  if (!state.syntax.isSignpostMode) return;
  const wIdx = parseInt(wIdxStr);
  const arr = state.syntax.answers[qId].signposts;
  const pos = arr.indexOf(wIdx);
  if (pos === -1) { arr.push(wIdx); el.classList.add('selected'); }
  else { arr.splice(pos, 1); el.classList.remove('selected'); }
}

let dragInfo = { isDragging: false, ghost: null, type: null, target: null };
document.querySelectorAll('.draggable-tag').forEach(tag => {
  tag.addEventListener('touchstart', startDrag, {passive: false});
  tag.addEventListener('mousedown', startDrag);
});

function startDrag(e) {
  if (state.syntax.isSignpostMode) return;
  if (e.type === 'touchstart') e.preventDefault(); 
  
  dragInfo.type = e.currentTarget.dataset.type;
  dragInfo.isDragging = true;
  
  dragInfo.ghost = document.createElement('div');
  dragInfo.ghost.id = 'drag-ghost';
  dragInfo.ghost.className = e.currentTarget.className;
  dragInfo.ghost.style.cssText = e.currentTarget.style.cssText;
  dragInfo.ghost.innerHTML = e.currentTarget.innerHTML;
  document.body.appendChild(dragInfo.ghost);

  const x = e.touches ? e.touches[0].clientX : e.clientX;
  const y = e.touches ? e.touches[0].clientY : e.clientY;
  moveDragGhost(x, y);
  
  if (e.type === 'touchstart') {
    document.addEventListener('touchmove', handleDragMove, {passive: false});
    document.addEventListener('touchend', handleDragEnd);
  } else {
    document.addEventListener('mousemove', handleDragMove);
    document.addEventListener('mouseup', handleDragEnd);
  }
}

function moveDragGhost(x, y) { if(dragInfo.ghost){ dragInfo.ghost.style.left = x+'px'; dragInfo.ghost.style.top = y+'px'; } }

function handleDragMove(e) {
  if (!dragInfo.isDragging) return;
  e.preventDefault();
  const x = e.touches ? e.touches[0].clientX : e.clientX;
  const y = e.touches ? e.touches[0].clientY : e.clientY;
  moveDragGhost(x, y);

  dragInfo.ghost.style.visibility = 'hidden';
  const elBelow = document.elementFromPoint(x, y);
  dragInfo.ghost.style.visibility = 'visible';

  const dz = elBelow?.closest('.dropzone');
  if (dragInfo.target && dragInfo.target !== dz) dragInfo.target.classList.remove('drag-over');
  if (dz && !dz.closest('.mode-signpost-active')) { dz.classList.add('drag-over'); dragInfo.target = dz; } 
  else { dragInfo.target = null; }
}

function handleDragEnd(e) {
  if (!dragInfo.isDragging) return;
  document.removeEventListener('mousemove', handleDragMove);
  document.removeEventListener('mouseup', handleDragEnd);
  document.removeEventListener('touchmove', handleDragMove);
  document.removeEventListener('touchend', handleDragEnd);

  if (dragInfo.ghost) { dragInfo.ghost.remove(); dragInfo.ghost = null; }
  if (dragInfo.target) {
    dragInfo.target.classList.remove('drag-over');
    const qId = dragInfo.target.dataset.qid;
    const cIdx = parseInt(dragInfo.target.dataset.cidx);
    const type = dragInfo.type;
    
    state.syntax.answers[qId].chunks[cIdx] = type;
    dragInfo.target.className = 'dropzone filled cursor-pointer';
    dragInfo.target.style.background = typeLabels[type].bg;
    dragInfo.target.style.borderColor = typeLabels[type].border;
    dragInfo.target.style.color = typeLabels[type].color;
    dragInfo.target.innerHTML = `<div class="text-[13px] font-bold text-center leading-tight"><span>${typeLabels[type].name}</span><br><span style="font-size:9px;opacity:0.8">${typeLabels[type].sub}</span></div>`;
  }
  dragInfo.isDragging = false; dragInfo.type = null; dragInfo.target = null;
}

function submitSyntax() {
  const idx = state.syntax.activeLevelIdx;
  const level = state.syntax.levels[idx];
  const questions = level.questions;
  
  let correctScore = 0; let totalScore = 0; let log = [];

  questions.forEach(q => {
    let cIdx = 0; let wIdx = 0; let hasErr = false;
    let visualHtml = [];

    q.segments.forEach(seg => {
      if (seg.t === 'text') { visualHtml.push(`<span>${seg.v}</span>`); } 
      else if (seg.t === 'word') {
        totalScore++;
        const isSel = state.syntax.answers[q.id].signposts.includes(wIdx);
        if (seg.sign) {
          if (isSel) { correctScore++; visualHtml.push(`<span class="p-sign mx-1">${seg.v}</span>`); }
          else { hasErr=true; visualHtml.push(`<span class="p-sign mx-1" style="border:2px dashed red">${seg.v}</span>`); }
        } else {
          if (isSel) { correctScore = Math.max(0, correctScore-1); hasErr=true; visualHtml.push(`<span class="bg-red-100 text-red-600 line-through decoration-2 px-1 rounded mx-1">${seg.v}</span>`); }
          else { correctScore++; visualHtml.push(`<span>${seg.v}</span>`); }
        }
        wIdx++;
      } 
      else if (seg.t === 'chunk') {
        totalScore++;
        const uAns = state.syntax.answers[q.id].chunks[cIdx];
        if (uAns === seg.ans) { correctScore++; visualHtml.push(`<span class="p-${seg.ans} mx-1 whitespace-nowrap">${seg.v}</span>`); }
        else { hasErr=true; visualHtml.push(`<span class="p-${seg.ans} mx-1 whitespace-nowrap" style="border:2px dashed red">${seg.v}</span>`); }
        cIdx++;
      }
    });
    log.push({ html: visualHtml.join(''), cn: q.cn, hasErr });
  });

  const accuracy = correctScore / totalScore;
  const isPass = accuracy >= 0.85; // 85% requirement to unlock

  // Update level stats
  level.lastAcc = accuracy;
  if(level.bestAcc === null || accuracy > level.bestAcc) level.bestAcc = accuracy;
  level.timeSpent += (Date.now() - state.syntax.startTime);
  level.lastDate = new Date().toISOString();
  state.syntax.startTime = null; // stop timer

  if (isPass) {
    level.status = 'passed';
    if (idx < 6 && state.syntax.levels[idx+1].status === 'locked') {
      state.syntax.levels[idx+1].status = 'unlocked';
    }
  }
  
  saveData();
  clearInterval(timerIntervals.syntax);
  
  // 新增：向老师的后台发送本次成绩！
  syncDataToBackend('syntax', idx + 1, accuracy, level.timeSpent, log);

  showSyntaxModal(accuracy, isPass, log, idx);
}

function showSyntaxModal(acc, isPass, log, idx) {
  const modal = document.getElementById('syntax-modal');
  const title = document.getElementById('modal-title');
  const sub = document.getElementById('modal-subtitle');
  const content = document.getElementById('modal-content');
  const btn = document.getElementById('modal-btn');

  modal.classList.remove('hidden'); modal.classList.add('flex');
  content.innerHTML = '';
  
  const pct = Math.round(acc * 100);

  if(isPass) {
    title.innerHTML = '<i class="fas fa-check-circle text-green-500"></i> 挑战成功！';
    sub.innerHTML = `本关准确率：<span class="text-green-600 font-black text-xl ml-1">${pct}%</span>`;
    btn.textContent = (idx < 6) ? "进入下一关" : "查看学习报告";
    btn.onclick = () => { 
      closeSyntaxModal(); 
      if(idx < 6) { 
        if(state.syntax.levels[idx+1].status === 'locked') state.syntax.levels[idx+1].status = 'unlocked';
        startSyntaxLevel(idx+1); switchTab('syntax'); 
      }
      else { switchTab('report'); }
    };
  } else {
    title.innerHTML = '<i class="fas fa-exclamation-triangle text-[var(--main)]"></i> 未达标！';
    sub.innerHTML = `本关准确率：<span class="text-[var(--main)] font-black text-xl ml-1">${pct}%</span> (需85%合格)`;
    btn.textContent = "再测一套";
    btn.onclick = () => { closeSyntaxModal(); startSyntaxLevel(idx); switchTab('syntax'); };
  }

  log.forEach((l, i) => {
    content.innerHTML += `
      <div class="bg-white border-2 border-gray-200 rounded-xl p-4 text-left">
        <div class="flex justify-between items-center mb-2 border-b border-gray-100 pb-2">
          <span class="font-bold text-gray-400">Q${i+1}</span>
          ${l.hasErr ? '<span class="text-xs font-bold text-red-500">发现错误</span>' : '<span class="text-xs font-bold text-green-500">完全正确</span>'}
        </div>
        <div class="font-nunito font-bold text-lg leading-[2.2] text-gray-800 mb-2">${l.html}</div>
        <div class="bg-[var(--paper)] p-2 rounded text-sm text-gray-600 font-bold">参考：${l.cn}</div>
      </div>
    `;
  });
}

function closeSyntaxModal() {
  document.getElementById('syntax-modal').classList.add('hidden');
  document.getElementById('syntax-modal').classList.remove('flex');
  window.scrollTo(0,0);
}

function updateReport() {
  // Vocab Breakdown
  let firstKnow = 0; let peeked = 0; let struggle = 0;
  state.vocab.words.forEach(w => {
    if(w.firstRes === 'know' && !w.peeked) firstKnow++;
    else if(w.peeked && w.firstRes === 'know') peeked++;
    else if(w.firstRes === 'meh' || w.firstRes === 'no') struggle++;
  });
  
  const vTotal = state.vocab.words.length;
  document.getElementById('r-v-total').textContent = vTotal;
  document.getElementById('r-v-first').textContent = firstKnow;
  document.getElementById('r-v-peeked').textContent = peeked;
  document.getElementById('r-v-struggle').textContent = struggle;
  
  let currentSessionVocabTime = 0;
  if(state.vocab.startTime) currentSessionVocabTime = Date.now() - state.vocab.startTime;
  document.getElementById('r-vocab-time').textContent = formatTime(Math.floor((state.vocab.timeSpent + currentSessionVocabTime)/1000));
  document.getElementById('r-vocab-date').textContent = formatDate(state.vocab.lastDate);

  // Syntax Warning Logic
  let completedCount = 0;
  let sumAcc = 0;
  state.syntax.levels.forEach(lvl => {
    if(lvl.lastAcc !== null) {
      completedCount++;
      sumAcc += lvl.lastAcc;
    }
  });
  
  const banner = document.getElementById('r-warning-banner');
  if (completedCount >= 2 && (sumAcc / completedCount) < 0.85) {
     banner.classList.remove('hidden');
  } else {
     banner.classList.add('hidden');
  }

  // Syntax Progress
  const sList = document.getElementById('r-syntax-list');
  sList.innerHTML = '';
  
  state.syntax.levels.forEach(lvl => {
    let statusHtml = ''; let accHtml = '--'; let timeStr = '--:--'; let actionHtml = '';
    
    if(lvl.lastAcc !== null) {
      const pct = Math.round(lvl.lastAcc * 100);
      accHtml = `${pct}%`;
      timeStr = formatTime(Math.floor(lvl.timeSpent/1000));
      
      if(lvl.status === 'passed') {
        statusHtml = `<span class="text-green-600 bg-green-50 px-2 py-1 rounded"><i class="fas fa-check"></i> 已通关</span>`;
        actionHtml = `<button onclick="startSyntaxLevel(${lvl.id-1}); switchTab('syntax')" class="text-[var(--clause)] underline text-xs">刷满分</button>`;
      } else {
        statusHtml = `<span class="text-red-600 bg-red-50 px-2 py-1 rounded"><i class="fas fa-xmark"></i> 不合格</span>`;
        actionHtml = `<button onclick="startSyntaxLevel(${lvl.id-1}); switchTab('syntax')" class="bg-[var(--clause)] text-white px-3 py-1 rounded-full shadow-sm active:scale-95 transition">再测一测</button>`;
      }
    } else {
      if(lvl.status === 'locked') {
        statusHtml = `<span class="text-gray-400 bg-gray-100 px-2 py-1 rounded"><i class="fas fa-lock"></i> 待解锁</span>`;
      } else {
        statusHtml = `<span class="text-blue-600 bg-blue-50 px-2 py-1 rounded">可挑战</span>`;
        actionHtml = `<button onclick="startSyntaxLevel(${lvl.id-1}); switchTab('syntax')" class="bg-[var(--ink)] text-white px-3 py-1 rounded-full shadow-sm active:scale-95 transition">开始</button>`;
      }
    }

    sList.innerHTML += `
      <div class="bg-white border-2 border-gray-200 rounded-xl px-4 py-3 report-table-row">
        <div class="text-[var(--ink)] font-black text-sm">Level ${lvl.id}</div>
        <div>${statusHtml}</div>
        <div class="text-gray-500 text-xs">最近 ${accHtml}<br><span class="font-normal opacity-70">用时 ${timeStr}</span><br><span class="font-normal opacity-70">${formatDate(lvl.lastDate)}</span></div>
        <div class="text-right">${actionHtml}</div>
      </div>
    `;
  });
}

