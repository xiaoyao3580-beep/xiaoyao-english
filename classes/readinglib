     ============================================================ -->
<style>
  #xy-gate{position:fixed;inset:0;z-index:2147483647;display:flex;align-items:center;justify-content:center;
    padding:24px;background:radial-gradient(circle at 12% 8%,#fff5dd 0,transparent 40%),
    radial-gradient(circle at 88% 4%,#ffe6dd 0,transparent 38%),#FBF6EC;
    font-family:"Noto Sans SC","Nunito",sans-serif;}
  #xy-gate .xy-card{width:100%;max-width:380px;background:#FFFDF8;border-radius:26px;padding:32px 26px;
    box-shadow:0 6px 0 rgba(0,0,0,.06),0 18px 44px rgba(46,42,38,.16);text-align:center;}
  #xy-gate .xy-emoji{font-size:36px;line-height:1}
  #xy-gate .xy-kicker{font-size:12px;font-weight:800;letter-spacing:1px;color:#E8552B;margin-top:10px}
  #xy-gate .xy-course{font-size:23px;font-weight:900;color:#2E2A26;margin:4px 0 2px}
  #xy-gate .xy-sub{font-size:13.5px;color:#6B6258;margin:0 0 22px}
  #xy-gate label{display:block;text-align:left;font-size:12.5px;font-weight:800;color:#6B6258;margin:0 0 6px 2px}
  #xy-gate input{width:100%;height:50px;border-radius:14px;border:2px solid #efe6d6;background:#fff;
    padding:0 16px;font-size:16px;color:#2E2A26;outline:none;margin-bottom:14px;transition:border-color .15s ease;}
  #xy-gate input:focus{border-color:#E8552B}
  #xy-gate button{width:100%;height:52px;border:none;border-radius:14px;cursor:pointer;margin-top:4px;
    background:#E8552B;color:#fff;font-size:16px;font-weight:800;letter-spacing:2px;
    box-shadow:0 5px 0 #c8431f;transition:transform .12s ease,box-shadow .12s ease;}
  #xy-gate button:active{transform:translateY(3px);box-shadow:0 2px 0 #c8431f}
  #xy-gate .xy-err{color:#d23b1f;font-size:13px;font-weight:700;min-height:18px;margin-top:12px}
  body.xy-locked{overflow:hidden!important}
</style>

<div id="xy-gate">
  <div class="xy-card">
    <div class="xy-emoji">📖</div>
    <div class="xy-kicker">EUGENE 的专属练习</div>
    <div class="xy-course">阅读博物馆</div>
    <p class="xy-sub">第 3–4 课 · 课后练习</p>
    <label for="xy-acc">账号</label>
    <input id="xy-acc" type="text" autocomplete="off" autocapitalize="off" autocorrect="off" placeholder="请输入账号">
    <label for="xy-pwd">密码</label>
    <input id="xy-pwd" type="password" autocomplete="off" placeholder="请输入密码">
    <button id="xy-btn">进　入</button>
    <div class="xy-err" id="xy-err"></div>
  </div>
</div>

<script>
(function(){
  /* ===== 账号密码：要改就改这两行 ===== */
  var ACCOUNT  = "eugene";
  var PASSWORD = "0987";
  /* ==================================== */
  document.body.classList.add('xy-locked');
  var gate = document.getElementById('xy-gate');
  var acc  = document.getElementById('xy-acc');
  var pwd  = document.getElementById('xy-pwd');
  var err  = document.getElementById('xy-err');
  function enter(){
    if(acc.value.trim() === ACCOUNT && pwd.value === PASSWORD){
      gate.style.display = 'none';
      document.body.classList.remove('xy-locked');
    } else {
      err.textContent = '账号或密码不对，请检查后再试。';
      pwd.value = '';
      pwd.focus();
    }
  }
  document.getElementById('xy-btn').addEventListener('click', enter);
  pwd.addEventListener('keydown', function(e){ if(e.key === 'Enter') enter(); });
  acc.addEventListener('keydown', function(e){ if(e.key === 'Enter') pwd.focus(); });
})();
</script>
