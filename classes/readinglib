function loadData() {
  const saved = localStorage.getItem('block_english_pro_data');
  if(saved) {
    try {
        const data = JSON.parse(saved);
        if(data.vocab && data.vocab.words) {
            state.vocab = data.vocab;
            // 新增：如果刷新或退出页面时词汇没做完，进度和计时自动清零
            if(!state.vocab.done) {
                state.vocab.words.forEach(w => { w.firstRes = null; w.peeked = false; });
                state.vocab.queue = state.vocab.words.map(w => w.id).sort(() => Math.random() - 0.5);
                state.vocab.mastered = 0;
                state.vocab.timeSpent = 0;
                state.vocab.startTime = null;
            }
        }
        if(data.syntax && data.syntax.levels) state.syntax = data.syntax;
    } catch(e) { console.error("Error loading data", e); }
  }
}

function checkDailyUnlock() {
  if (!state.syntax.firstPlayDate) {
    state.syntax.firstPlayDate = new Date().toISOString();
    saveData();
    return;
  }
  const firstPlay = new Date(state.syntax.firstPlayDate);
  const today = new Date();
  
  firstPlay.setHours(0,0,0,0);
  today.setHours(0,0,0,0);
  
  const diffDays = Math.floor((today - firstPlay) / (1000 * 60 * 60 * 24));
  if (diffDays > 0) {
    for(let i = 1; i <= Math.min(6, diffDays); i++) {
      if (state.syntax.levels[i].status === 'locked') {
        state.syntax.levels[i].status = 'unlocked';
      }
    }
    saveData();
  }
}

function initApp() {
  loadData();
  checkDailyUnlock();
  
  if(state.vocab.queue.length === 0 && !state.vocab.done) {
    state.vocab.queue = state.vocab.words.map((w) => w.id).sort(() => Math.random() - 0.5);
  }
  
  renderVocab();
  updateReport();
  
  navToSyntax(false);
}

function saveData() {
  localStorage.setItem('block_english_pro_data', JSON.stringify({ vocab: state.vocab, syntax: state.syntax }));
  updateReport();
}

